# Copy this file to robot.env and set your own name.
# robot.env is gitignored so your personal info never gets committed.
OWNER_NAME=YourName
GAMING_PC_IP=192.168.1.100
# Optional: explicit Wake-on-LAN target if the auto-learned MAC can't wake the PC
# WOL_MAC=AA:BB:CC:DD:EE:FF
# Optional: your phone's MAC for presence detection ("is my phone home")
# PHONE_MAC=AA:BB:CC:DD:EE:FF
HOME_LATITUDE=0.0
HOME_LONGITUDE=0.0
HOME_CITY=Your City, ST
STATION_NAME=STATION-01
